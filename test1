-- ================================================
-- OVERLAY
-- ================================================
local function clearOverlay()
    for _, entry in ipairs(overlayBills) do
        if entry.bb and entry.bb.Parent then entry.bb:Destroy() end
    end
    overlayBills = {}
end

local function buildOverlay()
    clearOverlay()
    if not overlayOn then return end

    local tables = getAllTables()
    local px = CONFIG.OVERLAY_PX
    local ph = math.round(px * 0.57)
    local ts = math.clamp(math.round(px * 0.28), 10, 40)

    for i, tbl in ipairs(tables) do
        local part = tbl:IsA("BasePart") and tbl or tbl:FindFirstChildWhichIsA("BasePart", true)
        if part then
            local isSel = (selectedTable == i)

            local bb = Instance.new("BillboardGui")
            bb.Size        = UDim2.new(0, px, 0, ph)
            bb.StudsOffset = Vector3.new(0, CONFIG.OVERLAY_STUDS, 0)
            bb.AlwaysOnTop = true
            bb.MaxDistance = CONFIG.OVERLAY_DISTANCE
            bb.Parent      = part

            local bg = Instance.new("Frame")
            bg.Size               = UDim2.new(1,0,1,0)
            bg.BackgroundColor3   = isSel and BG_HIGHLIGHT or BG_NORMAL
            bg.BackgroundTransparency = 0.15
            bg.BorderSizePixel    = 0
            bg.Parent             = bb
            do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,8); c.Parent = bg end

            local stroke = Instance.new("UIStroke")
            stroke.Thickness = isSel and 2.5 or 1
            stroke.Color     = isSel and COLOR_HIGHLIGHT or Color3.fromRGB(50,100,140)
            stroke.Parent    = bg

            local numLbl = Instance.new("TextLabel")
            numLbl.Size               = UDim2.new(1,0,1,0)
            numLbl.BackgroundTransparency = 1
            numLbl.Text               = tostring(i)
            numLbl.TextColor3         = isSel and COLOR_HIGHLIGHT or COLOR_NORMAL
            numLbl.TextSize           = isSel and (ts + 4) or ts
            numLbl.Font               = Enum.Font.GothamBold
            numLbl.Parent             = bg

            table.insert(overlayBills, { bb = bb, bg = bg, lbl = numLbl, stroke = stroke, idx = i })
        end
    end
end

local function refreshHighlight()
    local ts = math.clamp(math.round(CONFIG.OVERLAY_PX * 0.28), 10, 40)
    for _, entry in ipairs(overlayBills) do
        local isSel = (selectedTable == entry.idx)
        entry.bg.BackgroundColor3 = isSel and BG_HIGHLIGHT or BG_NORMAL
        entry.lbl.TextColor3      = isSel and COLOR_HIGHLIGHT or COLOR_NORMAL
        entry.lbl.TextSize        = isSel and (ts + 4) or ts
        entry.stroke.Color        = isSel and COLOR_HIGHLIGHT or Color3.fromRGB(50,100,140)
        entry.stroke.Thickness    = isSel and 2.5 or 1
    end
end

