                table.sort(servers, function(a,b)
                    return (a.playing or 0) > (b.playing or 0)
                end)

                for i, srv in ipairs(servers) do
                    if i > 20 then break end
                    local playing  = srv.playing    or 0
                    local maxPl    = srv.maxPlayers or 0
