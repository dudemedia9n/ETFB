-- CAPTURE SYSTEM
-- ================================================
-- capturedRemote & capturedArgs diisi saat user klik "Capture" lalu klik manual
local capturedRemote   = nil
local capturedArgs     = nil
local captureListening = false

local function setupNamecallCapture()
    if not getrawmetatable then
        tCaptureVal.Text       = "⚠ getrawmetatable N/A"
        tCaptureVal.TextColor3 = Color3.fromRGB(255,100,80)
        return
    end
    local mt = getrawmetatable(game)
    if not mt then return end
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        -- WAJIB: selalu jalankan oldNamecall agar game tidak rusak
        -- Kita cuma "mengintip", TIDAK memblokir apapun
        local results = table.pack(oldNamecall(self, ...))

        -- Hanya proses saat captureListening aktif dan method FireServer
        if captureListening
            and getnamecallmethod() == "FireServer"
            and typeof(self) == "Instance"
            and self:IsA("RemoteEvent") then

            local args = {...}
            for i, v in ipairs(args) do
            end
            capturedRemote   = self
            capturedArgs     = args
            captureListening = false

            tCaptureVal.Text       = "✅ " .. self.Name .. " (" .. #args .. " args)"
            tCaptureVal.TextColor3 = Color3.fromRGB(80,255,140)
            captureBtn.BackgroundColor3 = Color3.fromRGB(30,100,50)
            captureBtn.Text             = "✅  Remote Captured!"
        end

        return table.unpack(results, 1, results.n)
    end)
    setreadonly(mt, true)
end
pcall(setupNamecallCapture)

