local function doAutoPlay()
    while autoPlaying do
        local tables = getAllTables()
        if #tables == 0 then
            statusLabel.Text = "⚠  Tidak ada meja ditemukan"
            task.wait(2)
        else
            local target = math.clamp(selectedTable or 1, 1, #tables)
            local tbl    = tables[target]

            local prompt = tbl:FindFirstChildOfClass("ProximityPrompt")
                or tbl:FindFirstChild("Prompt", true)

            if prompt and prompt:IsA("ProximityPrompt") then
                fireproximityprompt(prompt)
                statusLabel.Text = string.format("✅  Bermain di Meja %d", target)
            else
                local remote = tbl:FindFirstChildOfClass("RemoteEvent")
                    or game:GetService("ReplicatedStorage"):FindFirstChild("PlayMinigame")
                if remote then
                    remote:FireServer(tbl)
                    statusLabel.Text = string.format("✅  Remote fired — Meja %d", target)
                else
                    statusLabel.Text = string.format("⚠  Meja %d: prompt tidak ditemukan", target)
                end
            end
        end
        task.wait(CONFIG.AUTO_PLAY_INTERVAL)
    end
end

