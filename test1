local function readSide(tbl, sideName)
    local board = tbl:FindFirstChild("PopcornBurstBoard")
    if not board then return "⚠ PopcornBurstBoard tidak ditemukan" end
    local side = board:FindFirstChild(sideName)
    if not side then return "⚠ " .. sideName .. " tidak ditemukan" end

    if side:IsA("StringValue") or side:IsA("IntValue") or side:IsA("NumberValue")
        or side:IsA("BoolValue") or side:IsA("ObjectValue") then
        return tostring(side.Value)
    end

    -- Model / Part: tampilkan class + child pertama
    local info     = "[" .. side.ClassName .. "]"
    local children = side:GetChildren()
    if #children > 0 then
        local names = {}
        for j = 1, math.min(4, #children) do
            table.insert(names, children[j].Name)
        end
        info = info .. " " .. table.concat(names, ", ")
        if #children > 4 then info = info .. "…" end
    end
    return info
end

