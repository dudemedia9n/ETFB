    local url = string.format("%s/plaza_leaderboard/%s.json", FB, myUsername)

    local function httpRequest(options)
        if http and http.request then
            return http.request(options)
        elseif syn and syn.request then
            return syn.request(options)
        elseif request then
            return request(options)
        end
        error("Tidak ada HTTP request function yang tersedia")
    end

    local function writeToFirebase(isWin, items, tokens)
        local wins       = 0
        local loses      = 0
        local tokensWin  = 0
        local tokensLose = 0
        local itemsWin   = {}
        local itemsLose  = {}

        pcall(function()
            local res = httpRequest({ Url = url, Method = "GET" })
            if res and res.Body and res.Body ~= "null" then
                local data = HS:JSONDecode(res.Body)
                if type(data) == "table" then
                    wins       = tonumber(data.wins)       or 0
                    loses      = tonumber(data.loses)      or 0
                    tokensWin  = tonumber(data.tokensWin)  or 0
                    tokensLose = tonumber(data.tokensLose) or 0
                    if type(data.itemsWin)  == "table" then itemsWin  = data.itemsWin  end
                    if type(data.itemsLose) == "table" then itemsLose = data.itemsLose end
                end
            end
        end)

        if isWin then
            wins      = wins + 1
            tokensWin = tokensWin + (tokens or 0)
            for _, item in ipairs(items or {}) do table.insert(itemsWin, item) end
            while #itemsWin  > 50 do table.remove(itemsWin,  1) end
        else
            loses      = loses + 1
            tokensLose = tokensLose + (tokens or 0)
            for _, item in ipairs(items or {}) do table.insert(itemsLose, item) end
            while #itemsLose > 50 do table.remove(itemsLose, 1) end
        end

        local ok, err = pcall(function()
            httpRequest({
                Url     = url,
                Method  = "PUT",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = HS:JSONEncode({
                    username   = myUsername,
                    wins       = wins,
                    loses      = loses,
                    tokensWin  = tokensWin,
                    tokensLose = tokensLose,
                    itemsWin   = itemsWin,
                    itemsLose  = itemsLose,
                }),
            })
        end)

        if ok then
            task.delay(1, function()
                if _G.__lbRefresh then pcall(_G.__lbRefresh) end
            end)
        else
        end
    end

    playerGui.ChildAdded:Connect(function(child)
        if child.Name ~= "MinigameResult" then return end

        task.spawn(function()
            task.wait(0.2)
            pcall(function()
                local overlay   = child:WaitForChild("Overlay", 3)
                local container = overlay and overlay:WaitForChild("Container", 3)
                if not container then return end

                local headerText = ""
                pcall(function()
                    local headerContainer = container:WaitForChild("HeaderContainer", 2)
                    local header = headerContainer and headerContainer:WaitForChild("Header", 2)
                    if header then
                        headerText = header:GetAttribute("Text") or header.Text or ""
                    end
                end)

                local upper  = headerText:upper()
                local isWin  = upper:find("WON")  ~= nil
                local isLose = upper:find("LOST") ~= nil or upper:find("LOSE") ~= nil
                if not isWin and not isLose then return end

                local items = {}
                pcall(function()
                    local itemScroll = container:WaitForChild("ItemScroll", 2)
                    for _, cell in ipairs(itemScroll:GetChildren()) do
                        if cell.Name:find("Cell") then
                            local imgBtn = cell:FindFirstChild("ImageButton")
                            local footer = imgBtn and imgBtn:FindFirstChild("FooterLabel")
                            if footer then
                                local itemName = footer:GetAttribute("Text") or footer.Text or ""
                                if itemName ~= "" then table.insert(items, itemName) end
                            end
                        end
                    end
                end)

                local tokens = 0
                pcall(function()
                    local tokenLabel = container:WaitForChild("TokenLabel", 2)
                    local children   = tokenLabel:GetChildren()
                    local tokenChild = children[6]
                    if tokenChild then
                        local raw = tokenChild:GetAttribute("Text") or tokenChild.Text or "0"
                        tokens = tonumber(raw:match("%d+")) or 0
                    end
                end)

                writeToFirebase(isWin, items, tokens)
            end)
        end)
    end)
end)


