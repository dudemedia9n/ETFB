-- ================================================
-- AUTO TIMING RING — Core Logic
-- ================================================
-- (state variables & cancelPendingHit sudah dideklarasi di atas, sebelum fullResetTimingState)

-- ── Perfect Scale Buffer ──────────────────────────
-- Kumpulkan sc dari Perfect hits saja (pasti milik kita)

local function calcFireTime(ringStartTime, ringDuration)
    return ringStartTime + ringDuration * (1 - CONFIG.TARGET_SCALE) - CONFIG.TIMING_OFFSET
end

-- Fire satu slot
local function fireSlot(hitRemote, slotIndex, perfectAt, ringDuration, playerIdx, isExtra)
    -- Update watchdog timer
    lastFiredTime = os.clock()

    local fireTime = workspace:GetServerTimeNow()
    local drift    = fireTime - perfectAt

    hitRemote:FireServer(CONFIG.HIT_ACTION, fireTime)

    local driftMs  = math.round(drift * 1000)
    local driftStr = driftMs >= 0 and string.format("+%dms", driftMs) or string.format("%dms", driftMs)
    local tag      = isExtra and "🔥+" or "🔥"

    if not isExtra then
        tLastHitVal.Text = string.format("%s FIRED  %s  slot:%s  p#%s",
            tag, driftStr, tostring(slotIndex or "?"), tostring(playerIdx or "?"))
        tLastHitVal.TextColor3 = math.abs(drift) < 0.003
            and Color3.fromRGB(50,255,120)
            or  math.abs(drift) < 0.008
                and Color3.fromRGB(120,255,150)
                or  math.abs(drift) < 0.020
                    and Color3.fromRGB(200,220,60)
                    or  Color3.fromRGB(255,160,50)
    end

end

local function scheduleHit(ringStartTime, ringDuration, slotIndex, playerIdx)
    local key = string.format("%.6f_%.6f", ringStartTime, ringDuration)
    if key == lastRingKey then return end
    lastRingKey        = key
    firedSlotsThisRing = {}

    cancelPendingHit()
    if ringDuration <= CONFIG.MIN_RING_DURATION then return end

    -- Simpan data ring ini agar bisa di-resume kalau toggle OFF→ON
    lastKnownRing = {
        ringStartTime = ringStartTime,
        ringDuration  = ringDuration,
        slotIndex     = slotIndex,
        playerIdx     = playerIdx,
    }

    local perfectAt = calcFireTime(ringStartTime, ringDuration)
    local serverNow = workspace:GetServerTimeNow()
    local waitTime  = perfectAt - serverNow

    tRingDurVal.Text = string.format(
        "%.3fs  sc→%.2f  p#%s  slot:%s",
        ringDuration, CONFIG.TARGET_SCALE,
        tostring(playerIdx or "?"), tostring(slotIndex or "?")
    )

    if waitTime < -0.08 then  -- toleransi 80ms — masih coba fire kalau sedikit telat
        tLastHitVal.Text      = "⏩ Terlambat (ring sudah lewat)"
        tLastHitVal.TextColor3 = Color3.fromRGB(180,180,80)
        return
    end

    if slotIndex then firedSlotsThisRing[tostring(slotIndex)] = true end

    pendingHitThread = task.spawn(function()
        -- Countdown live
        local countdownConn
        countdownConn = game:GetService("RunService").Heartbeat:Connect(function()
            if not timingOn then countdownConn:Disconnect(); return end
            local rem = perfectAt - workspace:GetServerTimeNow()
            if rem <= 0 then
                tCountdownVal.Text      = "🔥 FIRE!"
                tCountdownVal.TextColor3 = Color3.fromRGB(80,255,140)
                countdownConn:Disconnect()
            else
                tCountdownVal.Text = string.format("%.3f s", rem)
                tCountdownVal.TextColor3 = rem < 0.10
                    and Color3.fromRGB(255,160,40)
                    or  Color3.fromRGB(200,220,240)
            end
        end)

        -- Fase 1: task.wait kasar sampai 30ms sebelum target (dulu 50ms)
        local coarseWait = waitTime - 0.030
        if coarseWait > 0 then task.wait(coarseWait) end

        -- Fase 2: busy-wait Heartbeat sampai 1.5ms sebelum (dulu 3ms)
        while workspace:GetServerTimeNow() < (perfectAt - 0.0015) do
            game:GetService("RunService").Heartbeat:Wait()
        end

        -- Fase 3: spinlock CPU tight sampai tepat target
        -- (cek timingOn di dalam loop agar bisa dihentikan saat toggle OFF)
        while workspace:GetServerTimeNow() < perfectAt do
            if not timingOn or not scriptActive then return end
        end

        if not timingOn or not scriptActive then countdownConn:Disconnect(); return end

        local hitRemote = getNetworkRemote(CONFIG.HIT_REMOTE_NAME)
        if hitRemote then
            fireSlot(hitRemote, slotIndex, perfectAt, ringDuration, playerIdx, false)
        else
            tLastHitVal.Text      = "⚠ remote tidak ditemukan"
            tLastHitVal.TextColor3 = Color3.fromRGB(255,100,80)
        end
    end)
end

-- Fire slot tambahan — HANYA jika slot index valid (bukan nil)
-- Kalau slot selalu nil/?, skip extra fire untuk cegah triple firing
local function scheduleExtraSlot(ringStartTime, ringDuration, slotIndex, playerIdx)
    if not timingOn or not scriptActive then return end

    -- Kalau slot tidak diketahui, jangan fire extra — cukup 1 fire per ring
    if slotIndex == nil then return end

    local slotKey = tostring(slotIndex)
    if firedSlotsThisRing[slotKey] then return end
    firedSlotsThisRing[slotKey] = true

    local perfectAt = calcFireTime(ringStartTime, ringDuration)
    local serverNow = workspace:GetServerTimeNow()
    local waitTime  = perfectAt - serverNow

    if waitTime < -0.08 then return end

    task.spawn(function()
        local coarseWait = waitTime - 0.030
        if coarseWait > 0 then task.wait(coarseWait) end

        while workspace:GetServerTimeNow() < (perfectAt - 0.0015) do
            game:GetService("RunService").Heartbeat:Wait()
        end
        while workspace:GetServerTimeNow() < perfectAt do end

        if not timingOn or not scriptActive then return end

        local hitRemote = getNetworkRemote(CONFIG.HIT_REMOTE_NAME)
        if hitRemote then
            fireSlot(hitRemote, slotIndex, perfectAt, ringDuration, playerIdx, true)
        end
    end)
end

