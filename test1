-- Helper: buat 1 input row dengan label + TextBox + tombol Apply
local function makeTimingInput(labelText, defaultVal, hintText, onApply)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1,0,0,56)
    row.BackgroundColor3 = Color3.fromRGB(18,18,28)
    row.BorderSizePixel  = 0
    row.Parent           = scrollBody
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,7); c.Parent = row end
    do local s = Instance.new("UIStroke"); s.Color = Color3.fromRGB(50,55,75); s.Thickness = 1; s.Parent = row end

    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size               = UDim2.new(1,-12,0,18)
    nameLbl.Position           = UDim2.new(0,10,0,4)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text               = labelText
    nameLbl.TextColor3         = Color3.fromRGB(80,200,255)
    nameLbl.TextSize           = 11
    nameLbl.Font               = Enum.Font.GothamBold
    nameLbl.TextXAlignment     = Enum.TextXAlignment.Left
    nameLbl.Parent             = row

    local box = Instance.new("TextBox")
    box.Size               = UDim2.new(1,-62,0,22)
    box.Position           = UDim2.new(0,10,0,26)
    box.BackgroundColor3   = Color3.fromRGB(25,25,40)
    box.BorderSizePixel    = 0
    box.Text               = tostring(defaultVal)
    box.TextColor3         = Color3.fromRGB(220,230,255)
    box.PlaceholderText    = hintText
    box.PlaceholderColor3  = Color3.fromRGB(80,90,110)
    box.TextSize           = 12
    box.Font               = Enum.Font.GothamBold
    box.ClearTextOnFocus   = false
    box.Parent             = row
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,5); c.Parent = box end
    do local p = Instance.new("UIPadding"); p.PaddingLeft = UDim.new(0,8); p.Parent = box end

    local applyBtn = Instance.new("TextButton")
    applyBtn.Size             = UDim2.new(0,44,0,22)
    applyBtn.Position         = UDim2.new(1,-52,0,26)
    applyBtn.BackgroundColor3 = Color3.fromRGB(30,120,80)
    applyBtn.Text             = "Apply"
    applyBtn.TextColor3       = Color3.fromRGB(180,255,210)
    applyBtn.TextSize         = 10
    applyBtn.Font             = Enum.Font.GothamBold
    applyBtn.AutoButtonColor  = false
    applyBtn.BorderSizePixel  = 0
    applyBtn.Parent           = row
    do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,5); c.Parent = applyBtn end
    applyBtn.MouseEnter:Connect(function() applyBtn.BackgroundColor3 = Color3.fromRGB(40,160,100) end)
    applyBtn.MouseLeave:Connect(function() applyBtn.BackgroundColor3 = Color3.fromRGB(30,120,80) end)

    local function tryApply()
        local val = tonumber(box.Text)
        if val then
            onApply(val)
            applyBtn.BackgroundColor3 = Color3.fromRGB(20,180,80)
            applyBtn.Text             = "✓"
            task.delay(1, function()
                if applyBtn and applyBtn.Parent then
                    applyBtn.BackgroundColor3 = Color3.fromRGB(30,120,80)
                    applyBtn.Text             = "Apply"
                end
            end)
        else
            applyBtn.BackgroundColor3 = Color3.fromRGB(180,40,40)
            applyBtn.Text             = "✗"
            task.delay(1, function()
                if applyBtn and applyBtn.Parent then
                    applyBtn.BackgroundColor3 = Color3.fromRGB(30,120,80)
                    applyBtn.Text             = "Apply"
                end
            end)
        end
    end

    applyBtn.MouseButton1Click:Connect(tryApply)
    box.FocusLost:Connect(function(enterPressed)
        if enterPressed then tryApply() end
    end)

    return box
end

