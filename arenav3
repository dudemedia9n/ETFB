-- PROXIMITY PROMPT SYSTEM
local PromptCache = {}
local PromptDistCache = {}

local function enableInstantPrompt(p)
    if not p or not p.Parent then return end
    if not PromptCache[p] then PromptCache[p] = p.HoldDuration end
    p.HoldDuration = 0
    p.Enabled = true -- [cite: 163]
    
    if not PromptDistCache[p] then PromptDistCache[p] = p.MaxActivationDistance end
    p.MaxActivationDistance = 50
end

local function getTakePrompts(target)
    local prompts = {}
    local seen = {}
    
    local function addPrompt(p)
        if p and p:IsA("ProximityPrompt") and not seen[p] then
            seen[p] = true
            table.insert(prompts, p)
        end
    end -- [cite: 164]

    pcall(function()
        local ro = target:FindFirstChild("Root")
        if ro then
            local tp = ro:FindFirstChild("TakePrompt")
            if tp then addPrompt(tp) end
        end
    end)

    if #prompts == 0 then
        local tp = target:FindFirstChild("TakePrompt", true)
        if tp then addPrompt(tp) end -- [cite: 165]
    end

    if #prompts == 0 then
        for _, d in ipairs(target:GetDescendants()) do
            addPrompt(d)
        end
    end
    return prompts
end

