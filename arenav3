createGUI()
player.CharacterAdded:Connect(function(charNew)
    char = charNew
    hrp = char:WaitForChild("HumanoidRootPart")
    setupCharacter(char)
    createGUI()
end)

local carryStage = "middle"
if hiddenfling then startFling() end
playAnimation(char)

while true do
    local carrying = char:FindFirstChild("RenderedBrainrot") ~= nil

    if carrying then
        local middlePos = useStaticPreCarryPos and STATIC_PRE_CARRY_POS or PRE_CARRY_POS -- [cite: 218]
        local finalPos = getRandomOffsetPosition(FINAL_EXECUTION_POS)

        if carryStage == "middle" then
            local tweenInfo = TweenInfo.new((hrp.Position - middlePos).Magnitude / CARRY_TWEEN_SPEED, Enum.EasingStyle.Linear)
            local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(middlePos)})
            tween:Play()
            tween.Completed:Wait() -- [cite: 219]
            
            if hasArrivedAtPosition(hrp.Position, middlePos, POSITION_TOLERANCE) then
                carryStage = "final"
            end
        elseif carryStage == "final" then -- [cite: 220]
            if (hrp.Position - finalPos).Magnitude > 1 then
                local dist = (hrp.Position - finalPos).Magnitude
                local tweenTime = math.max(dist / CARRY_TWEEN_SPEED, MIN_TWEEN_TIME)
                local tween = TweenService:Create(hrp, TweenInfo.new(tweenTime), {CFrame = CFrame.new(finalPos)})
                tween:Play() -- [cite: 221]
                tween.Completed:Wait()
            end
            task.wait(arrivalDelay)
            task.wait(0.5)
            PRE_CARRY_POS = getClosestTarget(hrp.Position, PRE_CARRY_POSITIONS)
            FINAL_EXECUTION_POS = getClosestTarget(hrp.Position, TARGET_POSITIONS)
            carryStage = "middle" -- [cite: 222]
        end
    else
        carryStage = "middle"
        local target = getClosestBrainrot()
        if target then
            local targetPos = target.Position + Vector3.new(0, heightOffset, 0)
            local distance = (hrp.Position - targetPos).Magnitude
            if distance > 1 then -- [cite: 223]
                local tweenTime = math.max(distance / tweenSpeed, MIN_TWEEN_TIME)
                local tween = TweenService:Create(hrp, TweenInfo.new(tweenTime), {CFrame = CFrame.new(targetPos)})
                tween:Play()
            end
        else
            local middlePos = useStaticPreCarryPos and STATIC_PRE_CARRY_POS or PRE_CARRY_POS -- [cite: 224]
            if (hrp.Position - middlePos).Magnitude > 1 then
                local tweenInfo = TweenInfo.new((hrp.Position - middlePos).Magnitude / CARRY_TWEEN_SPEED, Enum.EasingStyle.Linear)
                local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(middlePos)})
                tween:Play()
            end
        end -- [cite: 225]
    end

    if autoHarpoonEnabled then
        task.spawn(function()
            local arenaFolder = Workspace:FindFirstChild(ARENA_FOLDER_NAME)
            if arenaFolder then
                for _, item in ipairs(arenaFolder:GetChildren()) do
                    if item.Name == "RenderedBrainrot" then
                        local prompts = getTakePrompts(item) -- [cite: 226]
                        for _, p in ipairs(prompts) do
                            enableInstantPrompt(p)
                            task.spawn(function() -- [cite: 227]
                                fireproximityprompt(p)
                            end)
                        end
                    end -- [cite: 228]
                end
            end
        end)
    end

    task.wait(ARRIVAL_THRESHOLD)
end
