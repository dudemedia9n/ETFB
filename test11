-- HOOK OnClientEvent
-- ================================================
local stateRemote = getRemoteByPath(CONFIG.STATE_REMOTE_PATH)

if stateRemote and stateRemote:IsA("RemoteEvent") then
    stateRemote.OnClientEvent:Connect(function(rawData)
        local ok, err = pcall(function()
            local packet  = rawData[1]; if not packet then return end
            local payload = packet[3];  if not payload then return end

            -- ── Struktur baru: session.private.myState ─────────────
            local session = payload.session
            if not session then return end
            local private = session.private
            if not private then return end
            local myState = private.myState
            if not myState then return end

            -- ── 1. Schedule hit dari myState langsung ──────────────
            -- Server sudah langsung kirim state milik kita — tidak perlu
            -- deteksi player index lagi
            local ringDuration  = myState.ringDuration
            local ringStartTime = myState.ringStartTime
            local slot          = myState.activeKernelSlot

            if ringDuration and ringStartTime
                and ringDuration > CONFIG.MIN_RING_DURATION
                and ringStartTime > 0 then

                local newKey = string.format("%.6f_%.6f", ringStartTime, ringDuration)

                if newKey ~= lastRingKey then
                    lastKnownRing = {
                        ringStartTime = ringStartTime,
                        ringDuration  = ringDuration,
                        slotIndex     = slot,
                        playerIdx     = nil,
                    }
                end

                if timingOn then
                    if newKey == lastRingKey and slot then
                        scheduleExtraSlot(ringStartTime, ringDuration, slot, nil)
                    else
                        scheduleHit(ringStartTime, ringDuration, slot, nil)
                    end
                end
            end

            -- ── 2. Baca lastResult dari myState ────────────────────
            local lr = myState.lastResult
            if lr and type(lr) == "table" and lr.rating then
                local rat   = lr.rating
                local acc   = lr.accuracy    or 0
                local pts   = lr.points      or 0
                local scale = lr.targetScale or 0

                local col =
                    rat == "Perfect" and Color3.fromRGB(50,255,120) or
                    rat == "Good"    and Color3.fromRGB(200,220,60)  or
                    rat == "Miss"    and Color3.fromRGB(255,70,70)   or
                    Color3.fromRGB(180,180,180)

                tLastHitVal.Text = string.format(
                    "%s  %.1f%%  +%d  sc:%.3f",
                    rat, acc, pts, scale
                )
                tLastHitVal.TextColor3 = col

                if rat == "Perfect" then

                    -- ── AutoTune Offset (sc-based) ──
                    if accurateModeOn then
                        table.insert(scSamples, scale)
                        if #scSamples > SC_BUF_MAX then table.remove(scSamples, 1) end
                        if #scSamples >= SC_BUF_MAX then
                            local sum = 0
                            for _, v in ipairs(scSamples) do sum = sum + v end
                            local avg   = sum / #scSamples
                            local error = avg - CONFIG.TARGET_SCALE
                            local step  = error * TUNE_GAIN
                            local newOff = math.clamp(CONFIG.TIMING_OFFSET - step, -0.1, 0.4)
                            CONFIG.TIMING_OFFSET = newOff
                            if timingOffsetBox then timingOffsetBox.Text = string.format("%.5f", newOff) end
                            scSamples = {}
                            tModeVal.Text = string.format("Tune→%.5f (err%+.3f)", newOff, error)
                            tModeVal.TextColor3 = math.abs(error) < 0.005
                                and Color3.fromRGB(80,255,140)
                                or  math.abs(error) < 0.015
                                    and Color3.fromRGB(200,220,60)
                                    or  Color3.fromRGB(255,160,50)
                        else
                            tModeVal.Text = string.format("Tune: %d/%d sample", #scSamples, SC_BUF_MAX)
                            tModeVal.TextColor3 = Color3.fromRGB(120,160,255)
                        end
                    end

                    -- ── ScoreTune smooth (pts-based) ──
                    if scoreTuneOn then
                        table.insert(accSamples, pts)
                        if #accSamples > ACC_BUF_MAX then table.remove(accSamples, 1) end
                        if #accSamples >= ACC_BUF_MAX then
                            local sum = 0
                            for _, v in ipairs(accSamples) do sum = sum + v end
                            local avgPts = sum / #accSamples
                            if lastAvgAcc > 0 and avgPts < lastAvgAcc then
                                scoreTuneDir = -scoreTuneDir
                            end
                            local newOff = math.clamp(
                                CONFIG.TIMING_OFFSET + scoreTuneDir * SCORE_STEP, -0.1, 0.4
                            )
                            lastAvgAcc           = avgPts
                            CONFIG.TIMING_OFFSET = newOff
                            if timingOffsetBox then timingOffsetBox.Text = string.format("%.5f", newOff) end
                            accSamples = {}
                            tModeVal.Text = string.format("Skor %.0f pts→%.5f", avgPts, newOff)
                            tModeVal.TextColor3 = avgPts >= 180
                                and Color3.fromRGB(80,255,140)
                                or  avgPts >= 120
                                    and Color3.fromRGB(200,220,60)
                                    or  Color3.fromRGB(255,160,50)
                        else
                            tModeVal.Text = string.format(
                                "Skor: %d/%d (%.0f pts)", #accSamples, ACC_BUF_MAX, pts
                            )
                            tModeVal.TextColor3 = Color3.fromRGB(255,200,60)
                        end
                    end

                    -- ── ScoreTune Agresif ──
                    if scoreTuneAggroOn then
                        table.insert(aggroSamples, pts)
                        if #aggroSamples > AGGRO_BUF_MAX then table.remove(aggroSamples, 1) end
                        if #aggroSamples >= AGGRO_BUF_MAX then
                            local sum = 0
                            for _, v in ipairs(aggroSamples) do sum = sum + v end
                            local avgPts = sum / #aggroSamples
                            if aggroLastAvgAcc > 0 and avgPts < aggroLastAvgAcc then
                                aggroDir = -aggroDir
                            end
                            local newOff = math.clamp(
                                CONFIG.TIMING_OFFSET + aggroDir * AGGRO_STEP, -0.1, 0.4
                            )
                            aggroLastAvgAcc      = avgPts
                            CONFIG.TIMING_OFFSET = newOff
                            if timingOffsetBox then timingOffsetBox.Text = string.format("%.5f", newOff) end
                            aggroSamples = {}
                            if avgPts >= 180 then
                                scoreTuneAggroOn = false
                                setToggleVisual(scoreTuneAggroBtn, scoreTuneAggroKnob, false)
                                scoreTuneOn  = true
                                accSamples   = {}
                                lastAvgAcc   = 0
                                scoreTuneDir = -1
                                setToggleVisual(scoreTuneBtn, scoreTuneKnob, true)
                                tModeVal.Text       = "✅ Auto→Smooth"
                                tModeVal.TextColor3 = Color3.fromRGB(80,255,140)
                            else
                                tModeVal.Text = string.format("⚡ %.0f pts→%.5f", avgPts, newOff)
                                tModeVal.TextColor3 = avgPts >= 120
                                    and Color3.fromRGB(255,160,50)
                                    or  Color3.fromRGB(255,80,80)
                            end
                        else
                            tModeVal.Text = string.format(
                                "⚡ %d/%d (%.0f pts)", #aggroSamples, AGGRO_BUF_MAX, pts
                            )
                            tModeVal.TextColor3 = Color3.fromRGB(255,120,60)
                        end
                    end

                elseif rat == "Good" then
                elseif rat == "Miss" then
                end
            end
        end)
        if not ok then warn("[AutoTiming] Parse error: " .. tostring(err)) end
    end)
else
end

