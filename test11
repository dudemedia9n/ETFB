-- ================================================
-- CONSOLE BUFFER — tangkap semua print/warn
-- ================================================
local consoleBuffer  = {}
local MAX_LINES      = 300   -- batas buffer

local function bufferLine(prefix, ...)
    local parts = {}
    for _, v in ipairs({...}) do
        table.insert(parts, tostring(v))
    end
    local line = prefix .. table.concat(parts, "  ")
    table.insert(consoleBuffer, line)
    if #consoleBuffer > MAX_LINES then
        table.remove(consoleBuffer, 1)
    end
end

-- Simpan original
local _origPrint = print
local _origWarn  = warn

-- Override: tulis ke console hanya kalau DEBUG = true
print = function(...)
    bufferLine("", ...)
    if DEBUG then _origPrint(...) end
end
warn = function(...)
    bufferLine("[WARN] ", ...)
    if DEBUG then _origWarn(...) end
end

