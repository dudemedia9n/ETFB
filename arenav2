local function getClosestTarget(pos)
    local closest = nil
    local shortestDist = math.huge
    for _, tPos in ipairs(targetPositions) do
        local dist = (pos - tPos).Magnitude
        if dist < shortestDist then
            shortestDist = dist
            closest = tPos
        end
    end
    return closest
end

local function getClosestExtra(pos)
